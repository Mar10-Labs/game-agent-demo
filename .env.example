GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.1
GROQ_MAX_TOKENS=1024

AGENT_TASK=Analizá las noticias tech de hoy y preparame un reporte para un senior backend engineer.
AGENT_MAX_ITERATIONS=9

ARTICLE_COUNT=5

ARTICLE_1_ID=1
ARTICLE_1_TITLE=Java 25 LTS: Virtual Threads hit production at Netflix scale
ARTICLE_1_SOURCE=InfoQ
ARTICLE_1_CATEGORY=JVM
ARTICLE_1_BODY=Netflix migró 200 servicios a Virtual Threads y reporta 40% más throughput. La presión sobre el GC cayó 22% y la latencia p99 se redujo a la mitad. El equipo destaca que el modelo mental de thread por request vuelve a ser viable a escala.

ARTICLE_2_ID=2
ARTICLE_2_TITLE=GitHub Copilot Workspace entra en GA — el dev loop completo se vuelve agéntico
ARTICLE_2_SOURCE=GitHub Blog
ARTICLE_2_CATEGORY=AI Tools
ARTICLE_2_BODY=Copilot ahora planea, escribe código, corre tests y abre PRs de forma autónoma a partir de una sola descripción en lenguaje natural. Early adopters reportan reducción del 3x en cycle time para features pequeñas.

ARTICLE_3_ID=3
ARTICLE_3_TITLE=Rust supera a Go en benchmarks de APIs backend por 3er año consecutivo
ARTICLE_3_SOURCE=TechEmpower
ARTICLE_3_CATEGORY=Performance
ARTICLE_3_BODY=Actix-web alcanza 1.2M req/s en hardware commodity. Go Fiber llega a 890k. JVM con Project Loom marca 1.05M req/s en workloads I/O-bound. Spring WebFlux queda en 760k.

ARTICLE_4_ID=4
ARTICLE_4_TITLE=PostgreSQL 17: replicación lógica amenaza a Kafka para workloads medianos
ARTICLE_4_SOURCE=Postgres Weekly
ARTICLE_4_CATEGORY=Databases
ARTICLE_4_BODY=Latencia sub-10ms en CDC hace opcional al message broker para equipos con menos de 50k eventos/seg. El patrón Outbox Pattern es ahora first-class en la documentación oficial de pg17.

ARTICLE_5_ID=5
ARTICLE_5_TITLE=Anthropic publica Claude con tool use paralelo y structured outputs
ARTICLE_5_SOURCE=Anthropic Blog
ARTICLE_5_CATEGORY=AI Models
ARTICLE_5_BODY=Las invocaciones paralelas de tools y el modo JSON estricto reducen la latencia de pipelines agénticos un 60%. La ventana de contexto se extiende para loops de agentes de larga duración.
